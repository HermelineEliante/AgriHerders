'From Pharo13.1.0SNAPSHOT of 15 June 2026 [Build information: Pharo-13.1.0+SNAPSHOT.build.734.sha.45e803df96aa5e64d0ba54450f49a879af08f6ac (64 Bit)] on 8 July 2026 at 2:51:25.070019 pm'!CMModel subclass: #AHModel	instanceVariableNames: ''	classVariableNames: ''	package: 'AgriHerders-Model'!!AHModel methodsFor: 'probes' stamp: '2026-07-06T13:58:12.755337+02:00'!averageBiomass	"^ (self @@ AHPlot collect: [ :p | p cover biomass ]) average"	"<probeNamed: 'averageBiomass' color: #green>"	^ self totalResidue + self naturalBiomass! !!AHModel methodsFor: 'probes' stamp: '2026-07-06T13:58:12.755547+02:00'!batchNumber "retourne le nombre total de vaches, pour suivre l'evolution de tout le troupeau"	<probeNamed: 'Cattle batchs' color: 'E74C3C' >	^(self @@ AHCattleBatch) size.! !!AHModel methodsFor: 'probes' stamp: '2026-07-06T13:58:12.755937+02:00'!cattleSize "retourne le nombre total de vaches, pour suivre l'evolution de tout le troupeau"	<probeNamed: 'Cattle size' color: 'E74C3C' >	self @@ AHCattleBatch ifEmpty: [ ^0 ].	^(self @@ AHCattleBatch collect: [ :each | each heads ]) sum.! !!AHModel methodsFor: 'probes' stamp: '2026-07-06T13:58:12.756553+02:00'!corporalCondition	"evolution de CC moyen de tout le troupeau (moyenne pondérée) "	<probeNamed: 'Corporal condition' color: 'F39C12'>	| heads |	self @@ AHCattleBatch ifEmpty: [ ^ 0 ].	heads := (self @@ AHCattleBatch collect: [ :each | each heads ]) sum.	heads = 0 ifTrue: [ ^ 0 ].	^ (self @@ AHCattleBatch collect: [ :each |		   each heads * each corporalCondition ]) sum / heads! !!AHModel methodsFor: 'probes' stamp: '2026-07-06T13:58:12.75684+02:00'!cottonSize	<probeNamed: 'Cotton size' color: 'F4F2DA' >	^ (self @@ AHPlot select: [ :p | p cover class = AHCotton ]) size! !!AHModel methodsFor: 'probes' stamp: '2026-07-06T13:58:12.758621+02:00'!globalFertility"moyenne de la fertilité de tous les plots : #(2 6 7) average"	<probeNamed: 'global fertility' color: #black>	^ (self @@ AHPlot collect: [ :p | p soilFertility ]) average! !!AHModel methodsFor: 'probes' stamp: '2026-07-06T13:58:12.761559+02:00'!maizeSize	<probeNamed: 'Maize size' color: 'F1F10F'>	^ (self @@ AHPlot select: [ :p | p cover class = AHMaize ]) size! !!AHModel methodsFor: 'probes' stamp: '2026-07-06T13:58:12.761907+02:00'!naturalBiomass	"<probeNamed: 'naturalBiomass' color: '5A9186'>"	^ ((self @@ AHPlot select: [ :p |		    p cover isKindOf: AHNaturalVegetation ]) collect: [ :p |		   p cover biomass ]) average! !!AHModel methodsFor: 'probes' stamp: '2026-07-06T13:58:12.762285+02:00'!naturalZoneFertility	"moyenne de la fertilité des plots en natural fertility : #(2 6 7) average"	<probeNamed: 'naturalZone fertility' color: #black>	| coll |	"coll := OrderedCollection new.	coll addAll: (self plotsCoveredBy: AHForest).	coll addAll: (self plotsCoveredBy: AHPasture).	coll addAll: (self plotsCoveredBy: AHBush ).	coll addAll: (self plotsCoveredBy: AHFallow )."	coll := self plotsCoveredBy: AHNaturalVegetation.	coll isEmpty ifTrue: [ ^ 0 ].	^ (coll collect: [ :p | p soilFertility ]) average! !!AHModel methodsFor: 'probes' stamp: '2026-07-06T13:58:12.762808+02:00'!sojaSize	<probeNamed: 'Soja size' color: 'B29EBB'>	^ (self @@ AHPlot select: [ :p | p cover class = AHSoja ]) size! !!AHModel methodsFor: 'probes' stamp: '2026-07-06T13:58:12.764308+02:00'!totalFertility	"Somme de la fertilité de tous les plots "	<probeNamed: 'total fertility' color: '2E4F70'>	^ (self @@ AHPlot collect: [ :p | p soilFertility ]) sum! !!AHModel methodsFor: 'probes' stamp: '2026-07-06T13:58:12.764671+02:00'!totalResidue	"<probeNamed: 'totalResidue' color: '9CB553'>"	^ ((self @@ AHPlot select: [ :p |		    p cover isKindOf: AHCultivatedVegetation ]) collect: [ :p |		   p cover biomass ]) average! !!AHModel methodsFor: 'initialization' stamp: '2026-07-06T13:58:12.757231+02:00'!createCattles	"Je crée 10 troupeax pour chaque éleveur"	| aCattle |	self @@ AHSedentary do: [ :eleveur |			aCattle := self newEntity: AHCattleBatch.			eleveur herd add: aCattle.			aCattle owner: eleveur.			aCattle moveTo:				(eleveur house) ]! !!AHModel methodsFor: 'initialization' stamp: '2026-07-06T13:58:12.758212+02:00'!createOneFarmFrom: aListOfIDs forAgent: aTypeOfAgent	| farmCells aFarm ag |	farmCells := self thePlots select: [ :c | aListOfIDs includes: c id ].	aFarm := self createAggregate: AHFarm from: farmCells.	ag := self newEntity: aTypeOfAgent.	ag myFarm: aFarm.	aFarm owner: ag.	(aTypeOfAgent inheritsFrom: AHHerder)		ifFalse: [ ag house: (self villagePlots at: ag id) ]		ifTrue: [				ag house:					(aFarm components detect: [ :c | c cover class = AHFulaniCamp ]) ].	ag class = AHExternalProprietary ifFalse: [			ag moveTo: ag house.			(aFarm includesCell: ag house) ifFalse: [				aFarm addComponent: ag house ] ]! !!AHModel methodsFor: 'initialization' stamp: '2026-07-06T17:22:49.895453+02:00'!initFarmsAndAgents	| farmCells |	self createOneFarmFrom: #( 17 18 25 26 27 33 ) forAgent: AHFarmer.	self createOneFarmFrom: #( 35 36 37 43 44 ) forAgent: AHFarmer.	self createOneFarmFrom: #( 32 40 ) forAgent: AHSedentary.	self createOneFarmFrom: #( 57 58 ) forAgent: AHSedentary.	"Ferme de cajou, proprietaires externes"	"	farmCells := self thePlots select: [ :c | #( 29 30 ) includes: c id ].	self createAggregate: AHFarm from: farmCells.	farmCells := self thePlots select: [ :c | #( 46 47 ) includes: c id ].	self createAggregate: AHFarm from: farmCells."	self createOneFarmFrom: #( 29 30  ) forAgent: AHExternalProprietary.	self createOneFarmFrom: #( 46 47 ) forAgent: AHExternalProprietary.	farmCells := self thePlots select: [ :c |		             #( 45 51 52 60 61 ) includes: c id ].	self newEntity: AHTranshumant. "locatedAt: (self cellAt: 1 at: 1)"	"act, c'est l'acteur en question, self allEntities est une collection de mes cinq acteurs"	(self allEntitiesOfClass: AHActor) do: [ :act |			act territory: self thePlots.			act others: (self allEntitiesOfClass: AHActor).			act others remove: act ]! !!AHModel methodsFor: 'initialization' stamp: '2026-07-06T13:58:12.760935+02:00'!initLandcover	1 to: 11 do: [ :i | (self cellAt: i) setLandcover: AHForest ].	#( 12 13 14 15 16 19 20 21 22 23 24 ) do: [ :i |		(self cellAt: i) setLandcover: AHPasture ].	#( 17 18 25 32 36 37 58 ) do: [ :i |		(self cellAt: i) setLandcover: AHMaize ].	#( 34 45 ) do: [ :i |		(self cellAt: i) setLandcover: AHSoja ].	#( 26 27 35 44 ) do: [ :i | (self cellAt: i) setLandcover: AHCotton ].	#( 33 43 ) do: [ :i | (self cellAt: i) setLandcover: AHCassava ].	#( 54 55 62 ) do: [ :i |		(self cellAt: i) setLandcover: AHFarmerHouse ].	#( 40 57 ) do: [ :i | (self cellAt: i) setLandcover: AHFulaniCamp ].	#( 29 30 46 47 51 52 60 61 ) do: [ :i |		(self cellAt: i) setLandcover: AHCashew ].	#( 28 31 34 38 39 41 42 48 49 50 53 56 59 63 64 ) do: [ :i |		(self cellAt: i) setLandcover: AHBush ]! !!AHModel methodsFor: 'initialization' stamp: '2026-07-06T16:57:18.531934+02:00'!init	<init>	self		createGridNumberOfRows: 8		numberOfColumns: 8		neighbourhood: 6		closed: true.	self initLandcover.	self initFarmsAndAgents.	self createCattles.	self @@ AHFarmer do: #setNobodysPlots.	"self makeAgentsScatteredInCells."	AHPlot activePovSelector: #povLandcover	"(self @@ AHFarm select: [ : f | f owner isNil ]) inspect"! !!AHModel methodsFor: 'accessing' stamp: '2026-07-06T13:58:12.758377+02:00'!forestPlots	"return the cells in  forest"	^ self plotsCoveredBy: AHForest! !!AHModel methodsFor: 'accessing' stamp: '2026-07-06T13:58:12.762545+02:00'!plotsCoveredBy: aTypeOfCover	"return the cells covered by aTypeOfCover"	^ self thePlots select: [ :c | c cover isKindOf: aTypeOfCover ]! !!AHModel methodsFor: 'accessing' stamp: '2026-07-06T13:58:12.763943+02:00'!theCattleBatches 	^ self @@ AHCattleBatch ! !!AHModel methodsFor: 'accessing' stamp: '2026-07-06T13:58:12.764068+02:00'!thePlots	^ self @@ AHPlot ! !!AHModel methodsFor: 'accessing' stamp: '2026-07-06T13:58:12.764815+02:00'!villagePlots	"return the 3 FarmerHouse cells"	^ self plotsCoveredBy:  AHFarmerHouse! !!AHModel methodsFor: 'control' stamp: '2026-07-06T17:27:54.945389+02:00'!step: t	"t = 1 => rainy saeson, si t est pair => dry season"	<control>	self class time: t.	self @@ AHPlot do: #resetCowsCounter.	t even		ifTrue: [ self stepDrySeason ]		ifFalse: [ "pair" self stepRainySeason ]! !!AHModel methodsFor: 'control' stamp: '2026-07-06T18:01:14.215251+02:00'!stepDrySeason	(self allEntitiesOfClass: AHActor) do: #harvest.	self thePlots do: #stepDrySeason. "Evolution naturelle des couverts"	"(self allEntitiesOfClass: AHActor) do: #dryStep"	(self allEntitiesOfClass: AHHerder) shuffled do: #moveHerd.	self @@ AHFarmer do: #sow.	self @@ AHSedentary do: #sowMaize.	self @@ AHCattleBatch reverseDo: #naturalMortality! !!AHModel methodsFor: 'control' stamp: '2026-07-06T18:00:49.801491+02:00'!stepRainySeason	self @@ AHFarmer do:  #rainyStep .	self thePlots do: #stepRainySeason.	(self allEntitiesOfClass: AHHerder) shuffled do: #moveHerd.	self @@ AHCattleBatch do: #reproduce! !!AHModel methodsFor: 'control' stamp: '2026-07-06T17:33:15.80415+02:00'!stepSemester	"t = 1 => rainy saeson, si t est pair => dry season"	<control>	self class time: self currentTimeStep .	self @@ AHPlot do: #resetCowsCounter.	self currentTimeStep even		ifTrue: [ self stepDrySeason ]		ifFalse: [ "pair" self stepRainySeason ]! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!AHModel class	instanceVariableNames: 'time'!!AHModel class methodsFor: 'as yet unclassified' stamp: '2026-07-06T13:58:12.754763+02:00'!modelName	^ 'AgriHerders'! !!AHModel class methodsFor: 'accessing' stamp: '2026-07-06T13:58:12.754906+02:00'!prefix	^ 'AH'! !!AHModel class methodsFor: 'accessing' stamp: '2026-07-06T16:58:47.390555+02:00'!time	<parameterIntegerDefault: 0>	^ time! !!AHModel class methodsFor: 'accessing' stamp: '2026-07-06T13:58:12.755141+02:00'!time: anObject	time := anObject! !