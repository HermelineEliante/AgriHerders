e' stamp: '2026-07-06T13:58:12.794693+02:00'!initialize	super initialize.	soilFertility := 5.	"self initializeWithRandomfertilitylevel."	area := 1. "ha"	cowsCounter := 0! !!AHPlot methodsFor: 'initialize' stamp: '2026-07-06T13:58:12.795981+02:00'!initializeWithRandomfertilitylevel	self soilFertility: (self selectRandomlyFrom: self possibleSoilFertilities)! !!AHPlot methodsFor: 'initialize' stamp: '2026-07-06T13:58:12.798549+02:00'!resetCowsCounter	self cowsCounter: 0! !!AHPlot methodsFor: 'pov' stamp: '2026-07-06T13:58:12.797251+02:00'!povBiomass	<pov>	cover ifNil: [ ^ CMPointOfView color: Color black ].	(self cover isKindOf: AHHabitation) ifTrue: [ ^ self povLandcover ].	^ CMPointOfView color: (self cover colorValue: (self cover biomass) min: 0 color: #white max: (self cover biomassMax ) color: self cover class myColor).	"^ CMPointOfView color: self cover class myColor"	! !!AHPlot methodsFor: 'pov' stamp: '2026-07-06T13:58:12.797554+02:00'!povCowsCounter	<pov>	cowsCounter = 0 ifTrue: [ ^ CMPointOfView color: #white ].	^ CMPointOfView color: (self			   colorAttribute: #cowsCounter			   min: 0			   max: 100			   color: Color brown)! !!AHPlot methodsFor: 'pov' stamp: '2026-07-06T13:58:12.797876+02:00'!povFarm	<pov>	(self getAggregateType: AHFarm)		ifNil: [ ^ CMPointOfView color: Color white ]		ifNotNil: [ ^ CMPointOfView color:  ((self getAggregateType: AHFarm) owner color) ]! !!AHPlot methodsFor: 'pov' stamp: '2026-07-06T13:58:12.798152+02:00'!povLandcover	<pov>	cover ifNil: [ ^ CMPointOfView color: Color black ].	^ CMPointOfView color: self cover class myColor! !!AHPlot methodsFor: 'pov' stamp: '2026-07-06T13:58:12.798375+02:00'!povSoilFertility	"	| aColor |	self soilFertility = 0 ifTrue: [ aColor := Color white ].	self soilFertility = 1 ifTrue: [ aColor := Color yellow ].	self soilFertility = 2 ifTrue: [ aColor := Color orange ].	self soilFertility = 3 ifTrue: [ aColor := Color green ]."	<pov>	^ CM