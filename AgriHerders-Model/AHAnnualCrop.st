'From Pharo13.1.0SNAPSHOT of 15 June 2026 [Build information: Pharo-13.1.0+SNAPSHOT.build.734.sha.45e803df96aa5e64d0ba54450f49a879af08f6ac (64 Bit)] on 8 July 2026 at 2:51:25.056896 pm'!AHCultivatedVegetation subclass: #AHAnnualCrop	instanceVariableNames: ''	classVariableNames: ''	package: 'AgriHerders-Model'!!AHAnnualCrop methodsFor: 'as yet unclassified' stamp: '2026-07-06T13:58:12.770158+02:00'!dryStep	"A la fin de la saison seche, l'annual crop devient Fallow"	| fallow |	super dryStep.	self isMature ifTrue: [  	fallow := self cell setLandcover: AHFallow.	fallow biomass: self residue.	isDead := true]! !!AHAnnualCrop methodsFor: 'testing' stamp: '2026-07-06T13:58:12.770339+02:00'!hasBeenHarvested	^ self biomass <= self residue ! !!AHAnnualCrop methodsFor: 'testing' stamp: '2026-07-06T13:58:12.770489+02:00'!isMature	"mature si age >= 0.5 y"	^ self age >= 0.5 ! !