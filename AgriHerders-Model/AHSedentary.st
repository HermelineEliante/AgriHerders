'From Pharo13.1.0SNAPSHOT of 15 June 2026 [Build information: Pharo-13.1.0+SNAPSHOT.build.734.sha.45e803df96aa5e64d0ba54450f49a879af08f6ac (64 Bit)] on 8 July 2026 at 2:51:25.033716 pm'!AHHerder subclass: #AHSedentary	instanceVariableNames: ''	classVariableNames: ''	package: 'AgriHerders-Model'!!AHSedentary methodsFor: 'pov' stamp: '2026-07-06T17:25:54.243231+02:00'!color^(CMColor colorOfNumber: self id)! !!AHSedentary methodsFor: 'pov' stamp: '2026-07-06T13:58:12.74223+02:00'!shape ^#diamond! !!AHSedentary methodsFor: 'control' stamp: '2026-07-06T13:58:12.741162+02:00'!harvest	"je ne récolte que le mais"	(self myFarm components select: [ :p | p cover class = AHMaize ])		do: [ :plot |				plot cover isMature ifTrue: [						self money: self money + (plot cover yield * plot cover price).						plot cover biomass: plot cover residue ] ]! !!AHSedentary methodsFor: 'control' stamp: '2026-07-06T13:58:12.741343+02:00'!initialize	super initialize.	agreement := true.	money := 1! !!AHSedentary methodsFor: 'control' stamp: '2026-07-06T13:58:12.74301+02:00'!sowMaize	"je fais continuellemnt du maïs sur une parcelle de ma propriété avec un niveau de fertilité > 0 "	| fertilePlots |	(self myFarm components select: [ :p | p cover class = AHMaize ])		isEmpty ifTrue: [ "plotWithFallow := self myFarm components				                  detect: [ :p | p cover class = AHFallow ]				                  ifNone: [ nil ].			plotWithFallow ifNotNil: [plotWithFallow setLandcover: AHCassava ] "			fertilePlots := (self myFarm components select: [ :p |				                 p cover class = AHFallow and: [					                 p soilFertility > 0 ] ]) sorted: [ :a :b |				                a soilFertility <= b soilFertility ].			fertilePlots ifNotEmpty: [ fertilePlots last setLandcover: AHMaize ] ]! !